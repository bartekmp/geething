{
  "name": "geething",
  "version": "0.10.2",
  "description": "A Firefox extension for Gmail notifications with multi-account support",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "web-ext run --source-dir=src --firefox=firefox",
    "seed": "node scripts/seed-dev.js",
    "sound": "node scripts/generate-sound.js",
    "build": "web-ext build --source-dir=src --ignore-files background/dev-seed.js shared/credentials.example.js --overwrite-dest",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "lint:ext": "web-ext lint --source-dir=src",
    "format": "prettier --write \"src/**/*.{js,css,html,json}\" \"tests/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.{js,css,html,json}\" \"tests/**/*.js\"",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.4.0",
    "vitest": "^3.0.0",
    "web-ext": "^8.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/bartekmp/geething.git"
  }
}
